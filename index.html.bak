<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Color Palette Generator</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>🎨 Color Palette Generator</h1>
        <p class="subtitle">Create beautiful color palettes from images or randomly</p>
        
        <div class="tabs">
            <button class="tab-btn active" data-tab="random">Random Palette</button>
            <button class="tab-btn" data-tab="image">Extract from Image</button>
        </div>
        
        <div id="random-tab" class="tab-content active">
            <div class="controls">
                <div class="control-group">
                    <label>Palette Type</label>
                    <select id="paletteType">
                        <option value="random">Random Colors</option>
                        <option value="analogous">Analogous</option>
                        <option value="complementary">Complementary</option>
                        <option value="triadic">Triadic</option>
                        <option value="monochromatic">Monochromatic</option>
                    </select>
                </div>
                <div class="control-group">
                    <label>Number of Colors: <span id="colorCountValue">5</span></label>
                    <input type="range" id="colorCount" min="3" max="10" value="5">
                </div>
                <button id="generateBtn" class="btn btn-primary">🎲 Generate New Palette</button>
            </div>
            
            <div class="palette-display" id="paletteDisplay"></div>
        </div>
        
        <div id="image-tab" class="tab-content">
            <div class="image-upload">
                <input type="file" id="imageInput" accept="image/*" hidden>
                <div class="drop-zone" id="dropZone">
                    <p>📁 Drop an image here or click to upload</p>
                    <p class="hint">Supports JPG, PNG, WebP, GIF</p>
                </div>
                <img id="previewImage" alt="Preview" style="display: none;">
            </div>
            <div class="palette-display" id="imagePaletteDisplay">
                <p class="empty-state">Upload an image to extract its colors</p>
            </div>
        </div>
        
        <div class="palette-actions">
            <button id="saveBtn" class="btn btn-secondary">💾 Save Palette</button>
            <button id="exportBtn" class="btn btn-secondary">📋 Export CSS</button>
        </div>
        
        <div class="saved-palettes" id="savedPalettes">
            <h3>💾 Saved Palettes</h3>
            <div class="saved-grid" id="savedGrid"></div>
        </div>
    </div>
    
    <script src="app.js"></script>
</body>
</html>
<script>
// API integration ready
const API = {
    async fetch(url, options = {}) {
        const response = await fetch(url, options);
        return response.json();
    }
};
</script>
<script>
// Offline indicator
const offlineIndicator = document.createElement('div');
offlineIndicator.textContent = '⚠️ Offline';
offlineIndicator.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#ff6b6b;color:white;text-align:center;padding:5px;display:none;';
document.body.appendChild(offlineIndicator);
window.addEventListener('online', () => offlineIndicator.style.display = 'none');
window.addEventListener('offline', () => offlineIndicator.style.display = 'block');
</script>
<script>
// Simple tutorial
const tutorialSteps = [
    { selector: 'h1', text: 'Welcome! This is the main title.' },
    { selector: 'button', text: 'Click here to perform actions.' }
];
let currentStep = 0;
function showTutorial() {
    if (currentStep < tutorialSteps.length) {
        const step = tutorialSteps[currentStep];
        const el = document.querySelector(step.selector);
        if (el) {
            const tooltip = document.createElement('div');
            tooltip.textContent = step.text;
            tooltip.style.cssText = 'position:absolute;background:#6f42c1;color:white;padding:10px;border-radius:5px;z-index:1000;';
            el.style.position = 'relative';
            el.appendChild(tooltip);
            setTimeout(() => tooltip.remove(), 3000);
        }
        currentStep++;
    }
}
// Show tutorial on first visit
if (!localStorage.getItem('tutorial-shown')) {
    setTimeout(showTutorial, 1000);
    localStorage.setItem('tutorial-shown', 'true');
}
</script>
<script>
// Templates gallery
const templates = [
    { name: 'Default', apply: () => {} },
    { name: 'Minimal', apply: () => document.body.style.fontFamily = 'system-ui, sans-serif' }
];
const templateSelect = document.createElement('select');
templates.forEach(t => {
    const opt = document.createElement('option');
    opt.value = t.name;
    opt.textContent = t.name;
    templateSelect.appendChild(opt);
});
templateSelect.onchange = (e) => {
    const template = templates.find(t => t.name === e.target.value);
    if (template) template.apply();
};
document.querySelector('.container')?.appendChild(templateSelect);
</script>
<script>
// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
    if (e.ctrlKey || e.metaKey) {
        switch(e.key) {
            case 's': e.preventDefault(); console.log('Save shortcut'); break;
            case 'r': e.preventDefault(); location.reload(); break;
            case 'f': e.preventDefault(); document.querySelector('input')?.focus(); break;
        }
    }
});
</script>
